{
  "name": "coffeeshop-mcp-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "MCP server for discovering the CoffeeShop API contract directly from Bruno collections.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "export:snapshot": "tsx src/exportSnapshot.ts",
    "generate:cloudflare-data": "tsx src/generateCloudflareData.ts",
    "dev:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "0.16.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.22.0"
  },
  "engines": {
    "node": ">=22"
  }
}
